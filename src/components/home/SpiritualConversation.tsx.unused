"use client";

// ============================================================
// SPIRITUAL AI — SPIRITUAL CONVERSATION (PAGE 2)
// Message box drives everything:
// 1. Question shown with bubble options
// 2. User clicks bubble → backend receives (question, answer, history)
// 3. Backend uses first-principles to generate next question
// 4. Repeat 3x, then final-share question, then quiz
// ============================================================

import React, { useState, useEffect, useRef, useCallback } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import {
  createInitialUserState,
  detectPattern,
  detectMBTISignals,
  computeMBTI,
  recommendProducts,
  getLifeStage,
  analyzeWordChoice,
  detectEnergyLevel,
  isTopicShift,
  type UserState,
  type GeneratedQuestion,
  type ConsciousnessReport,
  type Product,
  MBTI_PROFILES,
} from '../../lib/spiritual-conversation-engine';

// ============================================================
// TYPES
// ============================================================

type ConversationPhase =
  | 'idle'
  | 'first_question'
  | 'ai_generating'
  | 'asking'
  | 'quiz_generating'
  | 'quiz'
  | 'report_generating'
  | 'report'
  | 'sales_funnel'
  | 'products';

interface Message {
  id: string;
  role: 'ai' | 'user';
  content: string;
  question?: string;  // The question this answer belongs to
  timestamp: number;
}

interface AnswerOption {
  text: string;
  subLabel?: string;
}

// ============================================================
// CHIP LABELS + FIRST QUESTIONS
// ============================================================

const CHIP_LABELS = [
  { id: 'feeling_lost', label: 'Feeling Lost' },
  { id: 'relationship_pain', label: 'Relationship Pain' },
  { id: 'career_confusion', label: 'Career Confusion' },
  { id: 'inner_emptiness', label: 'Inner Emptiness' },
  { id: 'anxiety_overthinking', label: 'Anxiety & Overthinking' },
  { id: 'i_dont_know', label: "I Don't Even Know" },
];

const CHIP_FIRST_QUESTIONS: Record<string, string> = {
  feeling_lost: "Is the lostness louder in the morning — or at night?",
  relationship_pain: "Are you trying to keep loving them — or trying to stop?",
  career_confusion: "No direction at all — or too many that feel wrong?",
  inner_emptiness: "When did you last feel full inside — even briefly?",
  anxiety_overthinking: "Is your mind louder about the past — or the future?",
  i_dont_know: "That's honest. If one area feels heaviest right now — what is it?",
};

// ============================================================
// MAIN COMPONENT
// ============================================================

export default function SpiritualConversation() {
  const [phase, setPhase] = useState<ConversationPhase>('idle');
  const [messages, setMessages] = useState<Message[]>([]);
  const [userState, setUserState] = useState<UserState | null>(null);
  const [currentQuestion, setCurrentQuestion] = useState<string | null>(null);
  const [currentOptions, setCurrentOptions] = useState<AnswerOption[]>([]);
  const [selectedChip, setSelectedChip] = useState<string | null>(null);
  const [round, setRound] = useState(0);  // How many questions answered
  const [quizQuestions, setQuizQuestions] = useState<GeneratedQuestion[]>([]);
  const [quizIndex, setQuizIndex] = useState(0);
  const [quizAnswers, setQuizAnswers] = useState<string[]>([]);
  const [selectedQuizOption, setSelectedQuizOption] = useState<number | null>(null);
  const [showQuizFeedback, setShowQuizFeedback] = useState(false);
  const [report, setReport] = useState<ConsciousnessReport | null>(null);
  const [products, setProducts] = useState<Product[]>([]);
  const [inputValue, setInputValue] = useState('');
  const [isTyping, setIsTyping] = useState(false);
  const [dots, setDots] = useState(0);
  const [waitingForUserInput, setWaitingForUserInput] = useState(false);
  const [engagementTimer, setEngagementTimer] = useState<NodeJS.Timeout | null>(null);
  const [isListening, setIsListening] = useState(false);
  const recognitionRef = useRef<any>(null);

  const chatRef = useRef<HTMLDivElement>(null);
  const inputRef = useRef<HTMLInputElement>(null);

  // ============================================================
  // PROACTIVE WARMUP
  // ============================================================
  const lastWarmupRef = useRef<number>(0);
  const triggerWarmup = async () => {
    const now = Date.now();
    if (now - lastWarmupRef.current < 30000) return; // Only warmup once every 30s
    lastWarmupRef.current = now;
    try {
      await fetch('/api/spiritual', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'warmup' }),
      });
    } catch (_) { }
  };

  useEffect(() => {
    triggerWarmup(); // Initial background warmup
  }, []);

  // ============================================================
  // VOICE: toggleListening
  // ============================================================

  const toggleListening = () => {
    if (isListening) {
      recognitionRef.current?.stop();
      setIsListening(false);
      return;
    }

    const SpeechRecognition = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
    if (!SpeechRecognition) {
      alert("Voice recognition not supported in this browser.");
      return;
    }

    if (!recognitionRef.current) {
      recognitionRef.current = new SpeechRecognition();
      recognitionRef.current.continuous = false;
      recognitionRef.current.onresult = (e: any) => {
        const transcript = e.results[0][0].transcript;
        setInputValue(transcript);
        setIsListening(false);
      };
      recognitionRef.current.onerror = () => setIsListening(false);
      recognitionRef.current.onend = () => setIsListening(false);
    }

    recognitionRef.current.start();
    setIsListening(true);
  };

  // ============================================================
  // INIT
  // ============================================================

  const handleInputFocus = () => {
    if (messages.length === 0 && phase === 'idle') {
      const greeting = "Your arrival here wasn't random.\n\nWhat is the weight you've been carrying the longest?";
      const options = [
        { text: "Relationship pain", subLabel: "" },
        { text: "Career confusion", subLabel: "" },
        { text: "Inner emptiness", subLabel: "" },
        { text: "Anxiety & overthinking", subLabel: "" }
      ];
      addAIMessage(greeting);
      setCurrentQuestion(greeting);
      setCurrentOptions(options);
    }
  };

  // ============================================================
  // KEYBOARD: quiz A/B keys
  // ============================================================

  useEffect(() => {
    const handleKey = (e: KeyboardEvent) => {
      if (phase !== 'quiz' || showQuizFeedback) return;
      if (e.key.toLowerCase() === 'a') handleQuizSelect(0);
      if (e.key.toLowerCase() === 'b') handleQuizSelect(1);
    };
    window.addEventListener('keydown', handleKey);
    return () => window.removeEventListener('keydown', handleKey);
  }, [phase, showQuizFeedback, quizAnswers]);

  // ============================================================
  // HELPERS
  // ============================================================

  const addMessage = useCallback((
    role: 'ai' | 'user',
    content: string,
    question?: string
  ): Message => {
    const msg: Message = { id: `${role}_${Date.now()}_${Math.random()}`, role, content, question, timestamp: Date.now() };
    setMessages(prev => [...prev, msg]);
    return msg;
  }, []);

  const addAIMessage = useCallback((content: string) => {
    return addMessage('ai', content);
  }, [addMessage]);

  const addUserMessage = useCallback((content: string, question?: string) => {
    return addMessage('user', content, question);
  }, [addMessage]);

  // ============================================================
  // PHASE: CHIP SELECTED → first question
  // ============================================================

  const handleChipSelect = async (chipId: string) => {
    const state = createInitialUserState(chipId);
    setUserState(state);
    setSelectedChip(chipId);
    setPhase('first_question');

    const question = CHIP_FIRST_QUESTIONS[chipId] || "What's the heaviest thing on your mind right now?";
    setCurrentQuestion(question);

    // Show options based on chip
    const options = getChipOptions(chipId);
    setCurrentOptions(options);

    addAIMessage(question);
    setDots(1);

    // Start 8-second engagement timer
    startEngagementTimer(chipId);
  };

  // ============================================================
  // ENGAGEMENT TIMER: 8-second window for user input
  // ============================================================

  const startEngagementTimer = (chipId: string) => {
    // Clear any existing timer
    if (engagementTimer) {
      clearTimeout(engagementTimer);
    }

    setWaitingForUserInput(true);

    // Set timer for 8 seconds
    const timer = setTimeout(async () => {
      setWaitingForUserInput(false);
      setEngagementTimer(null);

      // If user hasn't typed anything, treat chip label as answer (PASSIVE USER)
      const chipLabel = CHIP_LABELS.find(c => c.id === chipId)?.label || 'Feeling Lost';
      await handlePassiveUserResponse(chipLabel);
    }, 8000);

    setEngagementTimer(timer);
  };

  const handlePassiveUserResponse = async (chipLabel: string) => {
    if (!userState || !currentQuestion || !selectedChip) return;

    // Treat the chip label as the user's answer
    const answer = `I'm feeling ${chipLabel.toLowerCase()}`;

    // Add user message
    addUserMessage(answer, currentQuestion);

    // Update state with passive user signal
    const updatedState: UserState = {
      ...userState,
      firstAnswer: userState.firstAnswer || answer,
      detectedPattern: userState.detectedPattern,
      patternConfidence: userState.patternConfidence || 0,
      triggerWords: userState.triggerWords || [],
      mbtiSignals: userState.mbtiSignals,
      exchangeHistory: [
        ...userState.exchangeHistory,
        { role: 'ai', content: currentQuestion },
        { role: 'user', content: answer },
      ],
      questionCount: userState.questionCount + 1,
      isPassiveUser: true, // Mark as passive user
    };

    setUserState(updatedState);
    setCurrentQuestion(null);
    setCurrentOptions([]);
    setPhase('ai_generating');

    const newRound = round + 1;
    setRound(newRound);
    setDots(Math.min(newRound, 5));

    // Transition to "asking" — AI is generating next question
    setIsTyping(true);
    await delay(800);
    addAIMessage("Decoding your pattern...");
    await delay(2000);
    setIsTyping(false);

    // PASSIVE USER PATH: Skip to products for most common MBTI types
    // Map chip to common MBTI types
    const chipToCommonMBTI: Record<string, string[]> = {
      feeling_lost: ['INFP', 'INFJ', 'ENFP'],
      relationship_pain: ['ISFJ', 'ENFJ', 'INFJ'],
      career_confusion: ['INTP', 'ENTP', 'ISTP'],
      inner_emptiness: ['INFP', 'INFJ', 'ISFP'],
      anxiety_overthinking: ['INTJ', 'INFP', 'ISTJ'],
      i_dont_know: ['INFP', 'INTP', 'ISTP'],
    };

    const commonTypes = chipToCommonMBTI[selectedChip] || ['INFP', 'INFJ', 'ENFP'];

    // Generate products for these types
    const recommendedProducts = commonTypes.flatMap(type => {
      const profile = MBTI_PROFILES[type as keyof typeof MBTI_PROFILES];
      if (!profile) return [];

      return [
        {
          id: `${type}-path-1`,
          name: `${type} Consciousness Blueprint`,
          headline: `The ${profile.name} Transformation Path`,
          whyYou: `Designed for your ${profile.corePattern} — ${profile.archetype}`,
          formats: ['Audio Journey', 'PDF Guide', '1:1 Session'],
          price: 47,
          originalPrice: 197,
          urgencyLine: `Your pattern is 72% dissolvable with the right key`,
          ctaText: 'See Your Path',
          imageQuery: `${type} spiritual transformation`,
          patternMatch: profile.corePattern,
        },
      ];
    }).slice(0, 3);

    setProducts(recommendedProducts);

    // Show passive user results with CTA to take the full quiz
    setPhase('products');
    addAIMessage("These found based on your signal. Take the 60-second decode for your exact path →");
  };

  // ============================================================
  // PHASE: USER ANSWERS → backend gets (question, answer, history)
  // Backend runs first-principles → next question
  // ============================================================

  const handleAnswer = async (answer: string) => {
    if (!userState || !currentQuestion) return;

    const questionAnswered = currentQuestion;

    // Add user message — tagged with the question it answers
    addUserMessage(answer, questionAnswered);

    // ─── TRACKING LOGIC ─────────────────────────────────────
    const now = Date.now();
    const responseTime = now - (userState.tracking?.lastMessageTimestamp || now);
    const words = analyzeWordChoice(answer);
    const prevUserMsg = messages.filter(m => m.role === 'user').slice(-1)[0]?.content;
    const energy = detectEnergyLevel(answer, prevUserMsg);
    const shifted = isTopicShift(answer, prevUserMsg);

    // Update local MBTI signals and pattern from the answer
    const mbtiSignals = detectMBTISignals(answer);
    const patternResult = detectPattern(answer);

    const updatedState: UserState = {
      ...userState,
      firstAnswer: userState.firstAnswer || answer,
      detectedPattern: patternResult.confidence > (userState.patternConfidence || 0)
        ? patternResult.pattern
        : userState.detectedPattern,
      patternConfidence: Math.max(patternResult.confidence, userState.patternConfidence || 0),
      triggerWords: [...new Set([...(userState.triggerWords || []), ...patternResult.triggerWords])],
      mbtiSignals: mergeSignals(userState.mbtiSignals, mbtiSignals),
      exchangeHistory: [
        ...userState.exchangeHistory,
        { role: 'ai', content: questionAnswered },
        { role: 'user', content: answer },
      ],
      questionCount: userState.questionCount + 1,
      tracking: {
        responseTimeMillis: [...(userState.tracking?.responseTimeMillis || []), responseTime],
        wordChoice: {
          emotional: (userState.tracking?.wordChoice?.emotional || 0) + words.emotional,
          analytical: (userState.tracking?.wordChoice?.analytical || 0) + words.analytical,
        },
        topicShifts: (userState.tracking?.topicShifts || 0) + (shifted ? 1 : 0),
        energyLevel: energy,
        lastMessageTimestamp: now,
      }
    };
    setUserState(updatedState);
    setCurrentQuestion(null);
    setCurrentOptions([]);
    setPhase('ai_generating');

    const newRound = round + 1;
    setRound(newRound);
    setDots(Math.min(newRound, 5));

    // Transition to "asking" — AI is generating next question
    setIsTyping(true);
    await delay(800);
    addAIMessage("I'm reading your pattern...");
    await delay(1500);
    setIsTyping(false);

    // Check if we should transition to quiz
    if (newRound >= 5) {
      await transitionToFinalShare(updatedState);
      return;
    }

    // Call backend with (currentQuestion, answer, fullHistory)
    try {
      const res = await fetch('/api/spiritual', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'process_answer',
          userState: updatedState,
          conversationHistory: updatedState.exchangeHistory,
          currentQuestion: questionAnswered,
          userAnswer: answer,
        }),
      });

      const data = await res.json();

      if (data.success && data.data) {
        const result = data.data;

        if (result.type === 'final_share') {
          // Final share question
          setCurrentQuestion(result.question);
          setCurrentOptions([]);
          setPhase('asking');
          addAIMessage(result.question);
        } else {
          // Next question
          setCurrentQuestion(result.question);
          setCurrentOptions(result.options?.map((o: any) => ({ text: o.text, subLabel: o.subLabel })) || []);
          setPhase('asking');

          if (result.inference) {
            console.log('[First-Principles Inference]', result.inference);
          }

          addAIMessage(result.question);
        }

        // Update pattern confidence if provided
        if (result.newPatternConfidence !== undefined) {
          setUserState(prev => prev ? { ...prev, patternConfidence: result.newPatternConfidence } : prev);
        }
      } else {
        // Fallback
        await askFallback(newRound, updatedState);
      }
    } catch {
      setIsTyping(false);
      await askFallback(newRound, updatedState);
    }
  };

  // ============================================================
  // FINAL SHARE — last question before quiz
  // ============================================================

  const transitionToFinalShare = async (state: UserState) => {
    setPhase('ai_generating');
    setIsTyping(true);
    await delay(1500);
    setIsTyping(false);

    const finalQuestion = "Last thing.\n\nIs there anything you haven't told me yet that feels important?\n\nSometimes what we hold back — is exactly what changes everything.";

    setCurrentQuestion(finalQuestion);
    setCurrentOptions([]);
    setPhase('asking');
    addAIMessage(finalQuestion);
  };

  // ============================================================
  // FALLBACK: if AI call fails
  // ============================================================

  const askFallback = async (currentRound: number, state: UserState) => {
    const fallbacks = [
      "How long has this been your default way of experiencing things?",
      "What have you tried before to change or fix this?",
      "Is there anything you haven't told me yet that feels important?",
    ];
    const q = fallbacks[Math.min(currentRound - 1, fallbacks.length - 1)];
    setCurrentQuestion(q);
    setCurrentOptions([]);
    setPhase('asking');
    addAIMessage(q);
  };

  // ============================================================
  // PHASE: QUIZ
  // ============================================================

  const transitionToQuiz = async () => {
    if (!userState) return;
    setPhase('quiz_generating');

    try {
      const res = await fetch('/api/spiritual', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'generate_quiz',
          userState,
          conversationHistory: userState.exchangeHistory,
        }),
      });
      const data = await res.json();

      if (data.success && data.data?.questions?.length > 0) {
        setQuizQuestions(data.data.questions);
        setQuizAnswers([]);
        setQuizIndex(0);
      } else {
        setQuizQuestions(getStaticQuizQuestions());
        setQuizAnswers([]);
        setQuizIndex(0);
      }
    } catch {
      setQuizQuestions(getStaticQuizQuestions());
      setQuizAnswers([]);
      setQuizIndex(0);
    }

    setPhase('quiz');
  };

  const handleQuizSelect = (index: number) => {
    if (selectedQuizOption !== null && quizAnswers[quizIndex]) return;
    const question = quizQuestions[quizIndex];
    if (!question) return;

    const selected = question.options[index];
    if (!selected) return;

    setSelectedQuizOption(index);
    setShowQuizFeedback(true);

    const newAnswers = [...quizAnswers];
    newAnswers[quizIndex] = selected.mbtiSignal || selected.text;
    setQuizAnswers(newAnswers);

    // Update MBTI signals from quiz
    if (selected.mbtiSignal && question.mbtiDimension) {
      const dim = question.mbtiDimension as keyof UserState['mbtiSignals'];
      if (['E_I', 'N_S', 'T_F', 'J_P'].includes(dim)) {
        setUserState(prev => {
          if (!prev) return prev;
          return {
            ...prev,
            mbtiSignals: {
              ...prev.mbtiSignals,
              [dim]: {
                signal: selected.mbtiSignal as any,
                confidence: Math.min(((prev.mbtiSignals as any)[dim]?.confidence || 0) + 0.3, 1.0),
              },
            },
          };
        });
      }
    }

    setTimeout(() => {
      setShowQuizFeedback(false);
      if (quizIndex < quizQuestions.length - 1) {
        setQuizIndex(prev => prev + 1);
        setSelectedQuizOption(null);
      } else {
        finalizeAndGenerateReport();
      }
    }, 900);
  };

  // ============================================================
  // REPORT
  // ============================================================

  const finalizeAndGenerateReport = async () => {
    if (!userState) return;
    setPhase('report_generating');

    const { type } = computeMBTI(userState.mbtiSignals);
    const finalState: UserState = { ...userState, confirmedMBTI: type };
    setUserState(finalState);

    try {
      const res = await fetch('/api/spiritual', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'generate_report',
          userState: finalState,
          conversationHistory: finalState.exchangeHistory,
        }),
      });
      const data = await res.json();

      if (data.success) {
        setReport(data.data.report);
        setProducts(data.data.products || []);
      } else {
        setReport(getFallbackReport(type));
        setProducts(recommendProducts(finalState.detectedPattern, type, finalState.budget, finalState.gender));
      }
    } catch {
      setReport(getFallbackReport(type));
      setProducts(recommendProducts(finalState.detectedPattern, type, userState.budget, userState.gender));
    }

    await delay(3000);
    setPhase('report');
  };

  // ============================================================
  // INPUT HANDLERS
  // ============================================================

  const handleSubmit = () => {
    const val = inputValue.trim();
    if (!val) return;

    // Clear engagement timer if user types (ENGAGED USER)
    if (engagementTimer) {
      clearTimeout(engagementTimer);
      setEngagementTimer(null);
      setWaitingForUserInput(false);
    }

    setInputValue('');
    handleAnswer(val);
  };

  const handleOptionClick = (opt: AnswerOption) => {
    // Clear engagement timer if user selects an option (ENGAGED USER)
    if (engagementTimer) {
      clearTimeout(engagementTimer);
      setEngagementTimer(null);
      setWaitingForUserInput(false);
    }

    handleAnswer(opt.text);
  };

  // ============================================================
  // CHIP OPTIONS per chip type
  // ============================================================

  function getChipOptions(chipId: string): AnswerOption[] {
    const map: Record<string, AnswerOption[]> = {
      feeling_lost: [
        { text: "In the morning — when I first wake up", subLabel: 'morning baseline' },
        { text: "At night — when everything goes quiet", subLabel: 'night void' },
      ],
      relationship_pain: [
        { text: "Still trying to love them", subLabel: 'holding on' },
        { text: "Trying to stop caring", subLabel: 'forced release' },
      ],
      career_confusion: [
        { text: "No direction at all — blank", subLabel: 'directionless' },
        { text: "Too many — and none feel right", subLabel: 'option paralysis' },
      ],
      inner_emptiness: [
        { text: "I remember a moment — briefly", subLabel: 'fading memory' },
        { text: "I honestly can't remember feeling full", subLabel: 'chronic void' },
      ],
      anxiety_overthinking: [
        { text: "The past — what I should have done differently", subLabel: 'retroactive' },
        { text: "The future — what could go wrong", subLabel: 'prospective' },
      ],
      i_dont_know: [
        { text: "My relationships — something is broken there", subLabel: 'relational' },
        { text: "My purpose — I don't know what I'm doing here", subLabel: 'existential' },
      ],
    };
    return map[chipId] || [{ text: "That's what I'm here about", subLabel: 'default' }];
  }

  // ============================================================
  // RENDER
  // ============================================================

  const showInputBox = phase === 'asking' || phase === 'first_question';
  const showChat = !['quiz', 'quiz_generating', 'report_generating', 'report'].includes(phase);
  const maxChatHeight = phase === 'report' ? '15vh' : phase === 'quiz' ? '28vh' : '52vh';

  return (
    <section style={{
      width: '100%',
      minHeight: '100vh',
      background: '#03030f',
      position: 'relative',
      overflow: 'hidden',
    }}>
      {/* Background glow */}
      <div style={{
        position: 'absolute',
        top: '15%',
        left: '50%',
        transform: 'translateX(-50%)',
        width: '80vw',
        height: '80vh',
        background: 'radial-gradient(circle, rgba(75,0,130,0.1) 0%, transparent 70%)',
        pointerEvents: 'none',
      }} />

      {/* Progress dots */}
      <div style={{
        display: 'flex',
        gap: '8px',
        padding: '28px 0 0',
        justifyContent: 'center',
        alignItems: 'center',
      }}>
        {[1, 2, 3, 4, 5].map(i => (
          <div key={i} style={{
            width: '6px',
            height: '6px',
            borderRadius: '50%',
            background: i < dots ? 'rgba(0,242,255,0.35)' : i === dots ? '#00f2ff' : 'rgba(255,255,255,0.15)',
            boxShadow: i === dots ? '0 0 10px rgba(0,242,255,0.5)' : 'none',
            transition: 'all 0.6s ease',
          }} />
        ))}
      </div>

      {/* Phase label */}
      <PhaseLabel phase={phase} round={round} />

      {/* ====================================================== */}
      {/* CHAT SECTION */}
      {/* ====================================================== */}
      <div style={{
        maxWidth: '820px',
        margin: '0 auto',
        padding: '0 20px',
      }}>
        <div
          ref={chatRef}
          style={{
            maxHeight: maxChatHeight,
            overflowY: 'auto',
            scrollbarWidth: 'none',
            paddingBottom: '12px',
            transition: 'max-height 0.6s ease',
          }}
        >
          <AnimatePresence>
            {messages.map((msg) => (
              <motion.div
                key={msg.id}
                initial={{ opacity: 0, y: 10 }}
                animate={{ opacity: 1, y: 0 }}
                transition={{ duration: 0.35, ease: [0.16, 1, 0.3, 1] }}
                style={{
                  display: 'flex',
                  flexDirection: msg.role === 'user' ? 'row-reverse' : 'row',
                  gap: '10px',
                  marginBottom: '16px',
                  alignItems: 'flex-start',
                }}
              >
                {/* Avatar */}
                <div style={{
                  width: '26px',
                  height: '26px',
                  borderRadius: '50%',
                  flexShrink: 0,
                  background: msg.role === 'ai'
                    ? 'radial-gradient(circle, rgba(75,0,130,0.9), rgba(30,27,75,1))'
                    : 'rgba(255,255,255,0.04)',
                  border: `0.5px solid ${msg.role === 'ai' ? 'rgba(0,242,255,0.3)' : 'rgba(255,255,255,0.1)'}`,
                  display: 'flex',
                  alignItems: 'center',
                  justifyContent: 'center',
                }}>
                  {msg.role === 'ai' && (
                    <div style={{ width: '7px', height: '7px', borderRadius: '50%', background: 'radial-gradient(circle, #35f8ff, #00f2ff)', boxShadow: '0 0 6px #00f2ff' }} />
                  )}
                  {msg.role === 'user' && (
                    <span style={{ fontSize: '9px', color: 'rgba(255,255,255,0.35)' }}>✦</span>
                  )}
                </div>

                {/* Bubble */}
                <div>
                  {msg.question && msg.role === 'user' && (
                    <p style={{
                      fontSize: '10px',
                      letterSpacing: '1px',
                      color: 'rgba(0,242,255,0.3)',
                      marginBottom: '4px',
                      fontFamily: "'Orbitron', sans-serif",
                      textTransform: 'uppercase',
                    }}>
                      re: {msg.question.length > 60 ? msg.question.slice(0, 60) + '…' : msg.question}
                    </p>
                  )}
                  <div style={{
                    maxWidth: '82%',
                    padding: '10px 14px',
                    borderRadius: msg.role === 'ai' ? '2px 14px 14px 14px' : '14px 2px 14px 14px',
                    background: msg.role === 'ai' ? 'rgba(0,242,255,0.05)' : 'rgba(255,255,255,0.04)',
                    border: `0.5px solid ${msg.role === 'ai' ? 'rgba(0,242,255,0.15)' : 'rgba(255,255,255,0.08)'}`,
                    fontSize: '15px',
                    fontWeight: 300,
                    lineHeight: 1.7,
                    color: msg.role === 'ai' ? 'rgba(255,255,255,0.88)' : 'rgba(255,255,255,0.58)',
                    fontStyle: msg.role === 'user' ? 'italic' : 'normal',
                    whiteSpace: 'pre-line',
                  }}>
                    {msg.content}
                  </div>
                </div>
              </motion.div>
            ))}
          </AnimatePresence>

          {/* Typing indicator */}
          {isTyping && <TypingIndicator />}
        </div>

        {/* =============================================== */}
        {/* BUBBLE OPTIONS — shown when currentQuestion is set */}
        {/* =============================================== */}
        {currentOptions.length > 0 && showInputBox && (
          <motion.div
            initial={{ opacity: 0, y: 8 }}
            animate={{ opacity: 1, y: 0 }}
            style={{ display: 'flex', flexWrap: 'wrap', gap: '8px', marginBottom: '10px', justifyContent: 'center' }}
          >
            {currentOptions.map((opt, i) => (
              <button
                key={i}
                onClick={() => handleOptionClick(opt)}
                style={{
                  padding: '8px 18px',
                  borderRadius: '20px',
                  background: 'rgba(0,242,255,0.05)',
                  border: '0.5px solid rgba(0,242,255,0.22)',
                  color: 'rgba(0,242,255,0.78)',
                  fontFamily: "'Cormorant Garamond', serif",
                  fontSize: '14px',
                  cursor: 'pointer',
                  fontStyle: 'italic',
                  transition: 'all 0.2s',
                }}
              >
                {opt.text}
              </button>
            ))}
            {/* Free-text toggle */}
            <button
              onClick={() => inputRef.current?.focus()}
              style={{
                padding: '8px 18px',
                borderRadius: '20px',
                background: 'rgba(255,255,255,0.03)',
                border: '0.5px solid rgba(255,255,255,0.12)',
                color: 'rgba(255,255,255,0.35)',
                fontFamily: "'Cormorant Garamond', serif",
                fontSize: '14px',
                cursor: 'pointer',
                fontStyle: 'italic',
              }}
            >
              Or type your own…
            </button>
          </motion.div>
        )}

        {/* Chip options — before first question */}
        {!selectedChip && messages.length <= 1 && (
          <motion.div
            initial={{ opacity: 0, y: 8 }}
            animate={{ opacity: 1, y: 0 }}
            style={{ display: 'flex', flexWrap: 'wrap', gap: '8px', marginBottom: '10px', justifyContent: 'center' }}
          >
            {CHIP_LABELS.map(chip => (
              <button
                key={chip.id}
                onClick={() => handleChipSelect(chip.id)}
                onMouseEnter={triggerWarmup}
                style={{
                  padding: '7px 16px',
                  borderRadius: '20px',
                  background: 'rgba(0,242,255,0.04)',
                  border: '0.5px solid rgba(0,242,255,0.18)',
                  color: 'rgba(0,242,255,0.7)',
                  fontFamily: "'Cormorant Garamond', serif",
                  fontSize: '13px',
                  cursor: 'pointer',
                  fontStyle: 'italic',
                  transition: 'all 0.2s',
                }}
              >
                {chip.label}
              </button>
            ))}
          </motion.div>
        )}

        {/* =============================================== */}
        {/* INPUT BOX — text input for free-form answers */}
        {/* =============================================== */}
        {showInputBox && (
          <div style={{ paddingBottom: '14px' }}>
            <div 
              onMouseEnter={triggerWarmup}
              style={{
                display: 'flex',
                alignItems: 'center',
                gap: '8px',
                background: 'rgba(0,242,255,0.04)',
                border: '0.5px solid rgba(0,242,255,0.18)',
                borderRadius: '50px',
                padding: '7px 8px 7px 18px',
              }}
            >
              <input
                type="text"
                ref={inputRef}
                value={inputValue}
                onFocus={handleInputFocus}
                onChange={e => setInputValue(e.target.value)}
                onKeyDown={e => {
                  if (e.key === 'Enter') {
                    e.preventDefault();
                    handleSubmit();
                  }
                }}
                placeholder="Your answer…"
                style={{
                  flex: 1,
                  background: 'none',
                  border: 'none',
                  outline: 'none',
                  color: 'rgba(255,255,255,0.85)',
                  fontFamily: "'Cormorant Garamond', serif",
                  fontSize: '15px',
                  fontWeight: 300,
                }}
              />
              <button
                type="button"
                onClick={toggleListening}
                style={{
                  background: 'none',
                  border: 'none',
                  color: isListening ? '#ff3cf5' : 'rgba(255,255,255,0.3)',
                  cursor: 'pointer',
                  fontSize: '18px',
                  padding: '0 8px',
                  transition: 'all 0.3s'
                }}
              >
                {isListening ? "⏺" : "🎙"}
              </button>
              <button
                type="button"
                onClick={handleSubmit}
                disabled={!inputValue.trim()}
                style={{
                  width: '32px',
                  height: '32px',
                  borderRadius: '50%',
                  background: inputValue.trim() ? 'rgba(0,242,255,0.12)' : 'rgba(255,255,255,0.03)',
                  border: `0.5px solid ${inputValue.trim() ? 'rgba(0,242,255,0.3)' : 'rgba(255,255,255,0.08)'}`,
                  cursor: inputValue.trim() ? 'pointer' : 'default',
                  display: 'flex',
                  alignItems: 'center',
                  justifyContent: 'center',
                  color: inputValue.trim() ? 'rgba(0,242,255,0.9)' : 'rgba(255,255,255,0.2)',
                  fontSize: '15px',
                  transition: 'all 0.2s',
                }}
              >
                →
              </button>
            </div>
          </div>
        )}
      </div>

      {/* ====================================================== */}
      {/* QUIZ GENERATING */}
      {/* ====================================================== */}
      {phase === 'quiz_generating' && (
        <SacredLoader text="Mapping your cognitive architecture…" />
      )}

      {/* ====================================================== */}
      {/* QUIZ — MBTIQuiz-style card */}
      {/* ====================================================== */}
      {phase === 'quiz' && quizQuestions[quizIndex] && (
        <QuizCard
          question={quizQuestions[quizIndex]}
          questionIndex={quizIndex}
          totalQuestions={quizQuestions.length}
          selectedOption={selectedQuizOption}
          showFeedback={showQuizFeedback}
          onSelect={handleQuizSelect}
        />
      )}

      {/* ====================================================== */}
      {/* REPORT GENERATING */}
      {/* ====================================================== */}
      {phase === 'report_generating' && (
        <SacredLoader
          text="Reading your consciousness…"
          subtexts={['Mapping your pattern…', 'Your path is forming…', 'Blueprint complete…']}
        />
      )}

      {/* ====================================================== */}
      {/* REPORT */}
      {/* ====================================================== */}
      {phase === 'report' && report && (
        <ReportView
          report={report}
          products={products}
          onContinue={() => setPhase('sales_funnel')}
        />
      )}

      {/* ====================================================== */}
      {/* SALES FUNNEL */}
      {/* ====================================================== */}
      {phase === 'sales_funnel' && report && (
        <SalesFunnelView
          report={report}
          userState={userState!}
          products={products}
        />
      )}
    </section>
  );
}

// ============================================================
// SUB-COMPONENTS
// ============================================================

function PhaseLabel({ phase, round }: { phase: ConversationPhase; round: number }): any {
  const labels: any = {
    idle: 'DECODING YOUR PATTERN',
    first_question: 'LOCATING THE FEELING',
    ai_generating: 'READING YOUR SIGNAL',
    asking: round >= 5 ? 'FINAL QUESTION' : `QUESTION ${round} OF 5`,
    quiz_generating: 'MAPPING YOUR MIND',
    quiz: 'CONFIRMING YOUR ARCHITECTURE',
    report_generating: 'YOUR BLUEPRINT FORMING',
    report: 'YOUR CONSCIOUSNESS BLUEPRINT',
    sales_funnel: 'YOUR TRANSFORMATION KIT',
    products: 'YOUR TRANSFORMATION PATH',
  };

  return (
    <motion.div
      key={phase}
      initial={{ opacity: 0 }}
      animate={{ opacity: 1 }}
      style={{
        fontFamily: "'Orbitron', sans-serif",
        fontSize: '8px',
        letterSpacing: '4px',
        color: 'rgba(0,242,255,0.38)',
        marginBottom: '10px',
        textAlign: 'center',
        textTransform: 'uppercase',
      }}
    >
      {labels[phase]}
    </motion.div>
  );
}

function TypingIndicator() {
  return (
    <motion.div
      initial={{ opacity: 0 }}
      animate={{ opacity: 1 }}
      style={{ display: 'flex', gap: '10px', alignItems: 'flex-start', marginBottom: '18px' }}
    >
      <div style={{
        width: '26px', height: '26px', borderRadius: '50%',
        background: 'radial-gradient(circle, rgba(75,0,130,0.9), rgba(30,27,75,1))',
        border: '0.5px solid rgba(0,242,255,0.3)',
        display: 'flex', alignItems: 'center', justifyContent: 'center',
      }}>
        <div style={{ width: '7px', height: '7px', borderRadius: '50%', background: 'radial-gradient(circle, #35f8ff, #00f2ff)' }} />
      </div>
      <div style={{ display: 'flex', gap: '5px', padding: '12px 14px', background: 'rgba(0,242,255,0.05)', border: '0.5px solid rgba(0,242,255,0.15)', borderRadius: '2px 14px 14px 14px', alignItems: 'center' }}>
        {[0, 0.15, 0.3].map((delay, i) => (
          <motion.div
            key={i}
            style={{ width: '4px', height: '4px', background: 'rgba(0,242,255,0.55)', borderRadius: '50%' }}
            animate={{ y: [0, -4, 0], opacity: [0.4, 1, 0.4] }}
            transition={{ duration: 1.2, repeat: Infinity, delay, ease: 'easeInOut' }}
          />
        ))}
      </div>
    </motion.div>
  );
}

// ============================================================
// QUIZ CARD
// ============================================================

function QuizCard({
  question,
  questionIndex,
  totalQuestions,
  selectedOption,
  showFeedback,
  onSelect,
}: {
  question: GeneratedQuestion;
  questionIndex: number;
  totalQuestions: number;
  selectedOption: number | null;
  showFeedback: boolean;
  onSelect: (index: number) => void;
}) {
  return (
    <motion.div
      key={questionIndex}
      initial={{ opacity: 0, scale: 0.96 }}
      animate={{ opacity: 1, scale: 1 }}
      exit={{ opacity: 0, scale: 0.96 }}
      transition={{ duration: 0.45, ease: [0.16, 1, 0.3, 1] }}
      style={{ padding: '0 20px 60px', maxWidth: '1200px', margin: '0 auto' }}
    >
      {/* Step counter */}
      <div style={{
        fontFamily: "'Orbitron', sans-serif",
        fontSize: 'clamp(0.7rem, 2vw, 1rem)',
        color: '#00f2ff',
        textTransform: 'uppercase',
        letterSpacing: '5px',
        marginBottom: '36px',
        textAlign: 'center',
        textShadow: '0 0 20px rgba(0,242,255,0.45)',
      }}>
        Step {questionIndex + 1} of {totalQuestions} — Mapping Your Mind
      </div>

      {/* Question card */}
      <div style={{
        background: 'linear-gradient(135deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.01) 100%)',
        border: '0.5px solid rgba(0,242,255,0.22)',
        clipPath: 'polygon(5% 0, 100% 0, 100% 70%, 95% 100%, 0 100%, 0 30%)',
        padding: 'clamp(1.5rem, 5vw, 2.5rem) clamp(1rem, 4vw, 2rem)',
        position: 'relative',
      }}>
        {/* Top glow */}
        <div style={{
          position: 'absolute',
          top: '-1px',
          left: '10%',
          width: '80%',
          height: '1px',
          background: 'linear-gradient(90deg, transparent, rgba(0,242,255,0.55), transparent)',
        }} />

        {question.contextLine && (
          <p style={{
            fontFamily: "'Cormorant Garamond', serif",
            fontSize: '14px',
            fontStyle: 'italic',
            color: 'rgba(0,242,255,0.48)',
            marginBottom: '14px',
            lineHeight: 1.6,
            textAlign: 'center',
          }}>
            {question.contextLine}
          </p>
        )}

        {/* Question text */}
        <h2 style={{
          fontFamily: "'Orbitron', sans-serif",
          fontSize: 'clamp(1rem, 4vw, 2.6rem)',
          fontWeight: 900,
          color: '#fff',
          textAlign: 'center',
          lineHeight: 1.2,
          letterSpacing: '2px',
          textTransform: 'uppercase',
          textShadow: '0 10px 40px rgba(0,0,0,0.8)',
          marginBottom: '36px',
          minHeight: '2.5em',
          display: 'flex',
          alignItems: 'center',
          justifyContent: 'center',
        }}>
          {question.question}
        </h2>

        {/* Options grid */}
        <div style={{
          display: 'grid',
          gridTemplateColumns: 'repeat(auto-fit, minmax(280px, 1fr))',
          gap: '1.4rem',
        }}>
          {question.options.map((opt, index) => {
            const isSelected = selectedOption === index;
            const wasSelectedBefore = selectedOption !== null && selectedOption !== index;
            const label = index === 0 ? 'A' : 'B';

            return (
              <motion.button
                key={index}
                onClick={() => onSelect(index)}
                whileHover={!wasSelectedBefore ? { scale: 1.03, y: -4 } : {}}
                whileTap={!wasSelectedBefore ? { scale: 0.98 } : {}}
                style={{
                  background: isSelected
                    ? 'rgba(0,242,255,0.2)'
                    : 'linear-gradient(135deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.01) 100%)',
                  border: isSelected
                    ? '1px solid #00f2ff'
                    : '0.5px solid rgba(0,242,255,0.22)',
                  clipPath: 'polygon(5% 0, 100% 0, 100% 70%, 95% 100%, 0 100%, 0 30%)',
                  padding: '1.4rem 1.8rem',
                  cursor: wasSelectedBefore ? 'default' : 'pointer',
                  transition: 'all 0.3s ease',
                  display: 'flex',
                  flexDirection: 'column',
                  alignItems: 'center',
                  gap: '0.65rem',
                  position: 'relative',
                  overflow: 'hidden',
                  boxShadow: isSelected
                    ? '0 0 40px rgba(0,242,255,0.28), inset 0 0 25px rgba(0,242,255,0.1)'
                    : '0 10px 30px rgba(0,0,0,0.5)',
                  opacity: wasSelectedBefore ? 0.4 : 1,
                }}
              >
                <span style={{
                  fontFamily: "'Orbitron', sans-serif",
                  fontSize: '1.1rem',
                  fontWeight: 900,
                  color: isSelected ? '#35f8ff' : 'rgba(0,242,255,0.55)',
                  letterSpacing: '3px',
                }}>
                  {label}
                </span>
                <span style={{
                  color: '#fff',
                  fontFamily: "'Orbitron', sans-serif",
                  fontSize: 'clamp(0.8rem, 2.5vw, 1.1rem)',
                  fontWeight: 700,
                  lineHeight: 1.3,
                  textAlign: 'center',
                  textTransform: 'uppercase',
                  letterSpacing: '1px',
                }}>
                  {opt.text}
                </span>
                {opt.subLabel && (
                  <span style={{
                    fontFamily: "'Inter', sans-serif",
                    fontSize: '0.78rem',
                    color: 'rgba(255,255,255,0.38)',
                    textAlign: 'center',
                    letterSpacing: '0',
                    textTransform: 'none',
                  }}>
                    {opt.subLabel}
                  </span>
                )}
                {showFeedback && isSelected && (
                  <motion.span
                    initial={{ opacity: 0, y: 6 }}
                    animate={{ opacity: 1, y: 0 }}
                    style={{
                      position: 'absolute',
                      bottom: '10px',
                      fontFamily: "'Orbitron', sans-serif",
                      fontSize: '0.68rem',
                      color: '#00f2ff',
                      textTransform: 'uppercase',
                      letterSpacing: '2px',
                      fontWeight: 700,
                    }}
                  >
                    Pattern detected…
                  </motion.span>
                )}
              </motion.button>
            );
          })}
        </div>

        {/* Keyboard hint */}
        <p style={{
          fontFamily: "'Orbitron', sans-serif",
          fontSize: '0.72rem',
          color: 'rgba(0,242,255,0.45)',
          textTransform: 'uppercase',
          letterSpacing: '2px',
          marginTop: '22px',
          textAlign: 'center',
        }}>
          Press A or B to select
        </p>
      </div>
    </motion.div>
  );
}

// ============================================================
// REPORT VIEW — THREE WRAPPERS (STUDY, JOURNEY, ACTION)
// ============================================================

function ReportView({ report, products, onContinue }: { report: ConsciousnessReport; products: Product[]; onContinue: () => void }) {
  const analyzers = ['INTJ', 'INTP', 'ENTJ', 'ENTP'];
  const feelers = ['INFP', 'INFJ', 'ENFP', 'ISFP', 'ENFJ', 'ESFP'];
  const doers = ['ISTJ', 'ISFJ', 'ESTJ', 'ESFJ', 'ISTP', 'ESTP'];

  const type = report.mbtiType.toUpperCase();
  const mode = analyzers.includes(type) ? 'study' : feelers.includes(type) ? 'journey' : 'action';

  // SHARED STYLES
  const containerStyle: React.CSSProperties = {
    padding: '0 24px 80px',
    maxWidth: mode === 'study' ? '900px' : '780px',
    margin: '0 auto',
    fontFamily: mode === 'study' ? "'Inter', monospace" : mode === 'journey' ? "'Cormorant Garamond', serif" : "'Orbitron', sans-serif",
  };

  return (
    <div style={containerStyle}>
      {/* ─── HEADER ─── */}
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        animate={{ opacity: 1, y: 0 }}
        style={{ textAlign: mode === 'journey' ? 'center' : 'left', marginBottom: '48px' }}
      >
        <p style={{ 
          fontFamily: "'Orbitron', sans-serif", 
          fontSize: '9px', 
          letterSpacing: '5px', 
          color: mode === 'study' ? '#00f2ff' : mode === 'journey' ? 'rgba(255,255,255,0.4)' : '#ff3cf5',
          marginBottom: '14px' 
        }}>
          {mode === 'study' ? 'SYSTEM DIAGNOSTIC COMPLETE' : mode === 'journey' ? 'YOUR SACRED MAP' : 'PROTOCOL INITIALIZED'}
        </p>
        <h1
          style={{ 
            fontSize: 'clamp(24px, 5vw, 42px)', 
            fontWeight: mode === 'study' ? 700 : 300, 
            color: '#fff', 
            lineHeight: 1.2, 
            marginBottom: '10px',
            textTransform: mode === 'action' ? 'uppercase' : 'none'
          }}
          dangerouslySetInnerHTML={{ __html: report.headlineText }}
        />
        <p style={{ fontSize: '18px', fontStyle: 'italic', color: 'rgba(255,255,255,0.5)' }}>
          {report.subText}
        </p>
      </motion.div>

      {/* ─── MAIN BLUEPRINT CARD ─── */}
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        animate={{ opacity: 1, y: 0 }}
        transition={{ delay: 0.3 }}
        style={{
          background: mode === 'study' ? 'rgba(0,0,0,0.4)' : mode === 'journey' ? 'linear-gradient(135deg, rgba(75,0,130,0.1), rgba(0,0,0,0.2))' : 'rgba(255,255,255,0.02)',
          border: `1px solid ${mode === 'study' ? '#00f2ff33' : mode === 'journey' ? '#ffffff11' : '#ff3cf533'}`,
          borderRadius: mode === 'study' ? '0' : '12px',
          padding: '32px',
          marginBottom: '40px',
          position: 'relative',
          overflow: 'hidden',
          boxShadow: mode === 'action' ? '0 0 30px rgba(255,60,245,0.1)' : 'none'
        }}
      >
        {/* Mode-Specific Icons */}
        <div style={{ position: 'absolute', top: '20px', right: '30px', fontSize: '24px', opacity: 0.3 }}>
          {mode === 'study' ? '📊' : mode === 'journey' ? '🪷' : '⚡'}
        </div>

        <div style={{ display: 'flex', gap: '24px', alignItems: 'center', marginBottom: '28px', paddingBottom: '22px', borderBottom: '1px solid rgba(255,255,255,0.1)' }}>
          <div style={{
            width: '70px', height: '70px', borderRadius: mode === 'study' ? '4px' : '50%',
            background: mode === 'study' ? '#00f2ff11' : mode === 'journey' ? 'rgba(255,255,255,0.05)' : '#ff3cf511',
            border: `1px solid ${mode === 'study' ? '#00f2ff' : mode === 'journey' ? '#fff' : '#ff3cf5'}`,
            display: 'flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0,
          }}>
            <span style={{ fontFamily: "'Orbitron', sans-serif", fontSize: '16px', fontWeight: 900, color: mode === 'study' ? '#00f2ff' : '#fff' }}>
              {report.mbtiType}
            </span>
          </div>
          <div>
            <h2 style={{ fontSize: '20px', fontWeight: 600, color: '#fff' }}>{report.mbtiName}</h2>
            <p style={{ fontSize: '14px', color: 'rgba(255,255,255,0.5)' }}>{report.archetype}</p>
          </div>
        </div>

        {/* Data Rows */}
        <div style={{ display: 'grid', gridTemplateColumns: mode === 'study' ? '1fr 1fr' : '1fr', gap: '16px' }}>
          {[
            { label: 'Core Pattern', value: report.corePattern },
            { label: 'Root Cause', value: report.rootCause },
            { label: 'Running Since', value: report.runningSince },
            { label: 'Urgency', value: `${report.urgencyPercent}%` },
            { label: 'Path', value: report.spiritualPath },
            { label: 'Est. Resolve', value: report.dissolutionTime },
          ].map((row, i) => (
            <div key={i} style={{ padding: '12px', background: 'rgba(255,255,255,0.03)', borderRadius: '4px' }}>
              <span style={{ display: 'block', fontSize: '10px', textTransform: 'uppercase', letterSpacing: '1px', color: 'rgba(255,255,255,0.3)', marginBottom: '4px' }}>
                {row.label}
              </span>
              <span style={{ fontSize: '15px', color: mode === 'study' && i % 2 === 0 ? '#00f2ff' : '#fff' }}>
                {row.value}
              </span>
            </div>
          ))}
        </div>
      </motion.div>

      {/* ─── SECTIONED CONTENT ─── */}
      <div style={{ display: 'flex', flexDirection: 'column', gap: '32px' }}>
        <Section mode={mode} label={mode === 'study' ? 'RESULTS & ROI' : mode === 'journey' ? 'YOUR STORY' : 'QUICK WIN'}>
          {report.validationParagraph}
        </Section>
        
