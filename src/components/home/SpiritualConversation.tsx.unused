    <div style={{ padding: '30px', background: 'rgba(0,242,255,0.03)', border: '1px solid rgba(0,242,255,0.15)', borderRadius: '16px', position: 'relative' }}>
      <div style={{ fontSize: '10px', color: '#00f2ff', marginBottom: '15px', fontWeight: 900, letterSpacing: '1px' }}>VALUE \${value} — YOURS FREE</div>
      <h4 style={{ fontSize: '18px', marginBottom: '12px', color: '#fff', fontFamily: "'Orbitron', sans-serif" }}>{title}</h4>
      <p style={{ fontSize: '14px', color: 'rgba(255,255,255,0.5)', lineHeight: 1.6 }}>{desc}</p>
    </div>
  );
}


