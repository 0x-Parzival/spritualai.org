function PexelsImage({ query }: { query: string }) {
  const [imageUrl, setImageUrl] = useState<string | null>(null);

  useEffect(() => {
    const fetchImage = async () => {
      try {
        const res = await fetch(`https://api.pexels.com/v1/search?query=${encodeURIComponent(query)}&per_page=1&orientation=landscape`, {
          headers: {
            'Authorization': '563492ad6f91700001000001bc600600000000000000000000000000' // Using a placeholder key or env
          }
        });
        const data = await res.json();
        if (data.photos?.[0]) setImageUrl(data.photos[0].src.medium);
      } catch (err) {
        console.error('Pexels error:', err);
      }
    };
    fetchImage();
  }, [query]);

  if (!imageUrl) return <div style={{ width: '100%', height: '100%', background: 'rgba(255,255,255,0.05)' }} />;
  return <img src={imageUrl} alt={query} style={{ width: '100%', height: '100%', objectFit: 'cover' }} />;
}

function ProductCard({ product, mode }: { product: Product; mode: string }) {
  return (
    <motion.div
      style={{
        background: 'rgba(255,255,255,0.03)',
        border: `1px solid ${mode === 'study' ? '#00f2ff22' : '#ffffff11'}`,
        padding: '0',
        display: 'grid',
        gridTemplateColumns: '180px 1fr auto',
        gap: '0',
        alignItems: 'stretch',
        borderRadius: mode === 'journey' ? '16px' : '4px',
        overflow: 'hidden'
      }}
    >
      <div style={{ width: '180px', position: 'relative' }}>
        <PexelsImage query={product.imageQuery || 'spiritual growth'} />
      </div>
      <div style={{ padding: '24px' }}>
        <p style={{ fontSize: '10px', color: 'rgba(255,255,255,0.4)', marginBottom: '4px', textTransform: 'uppercase', letterSpacing: '1px' }}>
          {product.formats.join(' • ')}
        </p>
        <h4 style={{ fontSize: '18px', color: '#fff', marginBottom: '8px' }}>{product.name}</h4>
        <p style={{ fontSize: '14px', color: 'rgba(255,255,255,0.5)', fontStyle: 'italic', lineHeight: 1.5 }}>{product.whyYou}</p>
      </div>
      <div style={{ textAlign: 'right', padding: '24px', display: 'flex', flexDirection: 'column', justifyContent: 'center', borderLeft: '1px solid rgba(255,255,255,0.05)' }}>
        <p style={{ fontSize: '24px', color: '#fff', marginBottom: '12px' }}>${product.price}</p>
        <button style={{
          padding: '10px 20px',
          background: mode === 'study' ? '#00f2ff' : mode === 'action' ? '#ff3cf5' : '#7000ff',
          color: '#fff',
          border: 'none',
          borderRadius: '4px',
          fontFamily: "'Orbitron', sans-serif",
          fontSize: '10px',
          fontWeight: 700,
          cursor: 'pointer',
          whiteSpace: 'nowrap'
        }}>
          {product.ctaText}
        </button>
      </div>
    </motion.div>
  );
}

// ============================================================
// SACRED LOADER
// ============================================================

function SacredLoader({ text, subtexts }: { text: string; subtexts?: string[] }) {
  const [currentText, setCurrentText] = useState(text);
  const [index, setIndex] = useState(0);

  useEffect(() => {
    if (!subtexts?.length) return;
    const interval = setInterval(() => {
      setIndex(prev => {
        const next = prev + 1;
        if (next < subtexts.length) {
          setCurrentText(subtexts[next]);
          return next;
        }
        return prev;
      });
    }, 2500);
    return () => clearInterval(interval);
  }, [subtexts]);

  return (
    <div style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', padding: '50px 20px', gap: '22px' }}>
      <motion.div
        animate={{ rotate: 360 }}
        transition={{ duration: 8, repeat: Infinity, ease: 'linear' }}
        style={{ fontSize: '44px', color: 'rgba(0,242,255,0.65)' }}
      >
        ✿
      </motion.div>
      <motion.p
        key={currentText}
        initial={{ opacity: 0 }}
        animate={{ opacity: 1 }}
        style={{ fontFamily: "'Orbitron', sans-serif", fontSize: '9px', letterSpacing: '4px', color: 'rgba(0,242,255,0.48)', textTransform: 'uppercase' }}
      >
        {currentText}
      </motion.p>
    </div>
  );
}

// ============================================================
// UTILITIES
// ============================================================

function delay(ms: number) {
  return new Promise(resolve => setTimeout(resolve, ms));
}

function mergeSignals(
  existing: UserState['mbtiSignals'],
  newSignals: Partial<UserState['mbtiSignals']>
): UserState['mbtiSignals'] {
  const result = { ...existing };
  for (const key of Object.keys(newSignals) as Array<keyof UserState['mbtiSignals']>) {
    const ns = newSignals[key];
    if (ns?.signal) {
      if (!result[key].signal || ns.confidence > result[key].confidence) {
        (result[key] as any) = { signal: ns.signal, confidence: Math.min((result[key].confidence || 0) + ns.confidence, 1.0) };
      }
    }
  }
  return result;
}

