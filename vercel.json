{
    "framework": "nextjs",
    "buildCommand": "next build",
    "installCommand": "npm install",
    "devCommand": "next dev",
    "ignoreCommand": "git diff --quiet HEAD^ HEAD ./",
    "headers": [
        {
            "source": "/(images|assets|MBTI|cosmic-compass)/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(.*).(png|jpg|jpeg|gif|webp|avif|svg|ico|js|css)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}